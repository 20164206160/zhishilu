{
  "analysis": {
    "analyzer": {
      "my_pinyin_analyzer": {
        "tokenizer": "keyword",
        "filter": ["my_pinyin"]
      }
    },
    "filter": {
      "my_pinyin": {
        "type": "pinyin",
        "keep_first_letter": true,
        "keep_full_pinyin": false,
        "keep_joined_full_pinyin": true,
        "keep_original": true,
        "limit_first_letter_length": 16,
        "remove_duplicated_term": true
      }
    }
  }
}
